# =============================================================================
# TRAEFIK DOCKER COMPOSE ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env and update with your actual values

# -----------------------------------------------------------------------------
# CLOUDFLARE CONFIGURATION (for SSL certificates)
# -----------------------------------------------------------------------------
# Get these from Cloudflare dashboard -> My Profile -> API Tokens
CF_DNS_API_TOKEN=your_cloudflare_dns_api_token_here
CF_API_EMAIL=your.email@example.com

# -----------------------------------------------------------------------------
# TRAEFIK CONFIGURATION
# -----------------------------------------------------------------------------
TRAEFIK_DOMAIN=yourdomain.com
TRAEFIK_EMAIL=your.email@example.com

# Traefik Dashboard Authentication (htpasswd format)
# Generate with: htpasswd -nb username password
# IMPORTANT: In .env file, escape each $ as $$
# Example: If htpasswd returns: $apr1$QpFu/KBL$g.nvmzpswh.Pfs4E3wVMS/
#          In .env file write:  $$apr1$$QpFu/KBL$$g.nvmzpswh.Pfs4E3wVMS/
# Format: username:$$apr1$$hash$$more_hash
TRAEFIK_DASHBOARD_AUTH=test:$$apr1$$94paikwj$$S3w9e.JKdYnlOI2ZU4d.O1

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# -----------------------------------------------------------------------------

# PostgreSQL 16
POSTGRES16_DB=myapp
POSTGRES16_USER=postgres
POSTGRES16_PASSWORD=secure_postgres16_password_change_me
POSTGRES16_PORT=5432

# PostgreSQL 17
POSTGRES17_DB=myapp
POSTGRES17_USER=postgres
POSTGRES17_PASSWORD=secure_postgres17_password_change_me
POSTGRES17_PORT=5433

# MongoDB 8  
MONGO8_INITDB_ROOT_USERNAME=mongo_admin
MONGO8_INITDB_ROOT_PASSWORD=secure_mongo8_password_change_me
MONGO8_INITDB_DATABASE=mongodb
MONGO8_PORT=27017

# Redis 7
REDIS7_PASSWORD=secure_redis7_password_change_me
REDIS7_PORT=6379

# -----------------------------------------------------------------------------
# PROXY CONFIGURATION (for setup.sh)
# -----------------------------------------------------------------------------
PROXY_USER=your_proxy_username_here
PROXY_PASS=your_proxy_password_here

# -----------------------------------------------------------------------------
# USER PASSWORD CONFIGURATION (for setup.sh --set-password)
# -----------------------------------------------------------------------------
# Password to set for the current user when using --set-password flag
# Leave empty to skip password change
USER_PASSWORD=your_user_password_here

# Proxy Configuration (Optional)
PROXY_URL=""  # "http://proxy.example.com:8080"
